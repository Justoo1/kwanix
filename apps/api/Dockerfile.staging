# ── Stage 1: build deps into isolated venv ────────────────────────────────────
FROM python:3.11-slim AS builder

WORKDIR /build

RUN pip install uv --no-cache-dir

COPY pyproject.toml .

# Install only production deps (no [dev] extras) into a virtual environment
RUN uv venv /opt/venv && \
    uv pip install --python /opt/venv/bin/python "." --no-cache

# ── Stage 2: staging runner ────────────────────────────────────────────────────
FROM python:3.11-slim AS runner

WORKDIR /app

ENV PATH="/opt/venv/bin:$PATH" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN addgroup --system kwanix && adduser --system --ingroup kwanix kwanix

COPY --from=builder /opt/venv /opt/venv

COPY --chown=kwanix:kwanix app/ ./app/
COPY --chown=kwanix:kwanix alembic/ ./alembic/
COPY --chown=kwanix:kwanix alembic.ini ./alembic.ini
COPY --chown=kwanix:kwanix entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

USER kwanix

EXPOSE 8000

ENTRYPOINT ["./entrypoint.sh"]
# 2 workers for staging — lower resource usage, full access log for debugging
CMD ["uvicorn", "app.main:app", \
     "--host", "0.0.0.0", \
     "--port", "8000", \
     "--workers", "2", \
     "--access-log"]
