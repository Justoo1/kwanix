# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://routpass:secret@localhost:5432/routpass_db

# === SECURITY ===
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === SESSION (Next.js) ===
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# === ARKESEL SMS ===
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=RoutePass

# === PAYMENTS ===
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_
FLUTTERWAVE_SECRET_KEY=

# === NEXT.JS ===
# Server-side (actions, server components inside Docker) — use Docker service name
API_INTERNAL_URL=http://api:8000
# Browser-side — use the host-exposed address
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === APP URLS ===
# public_app_url — Next.js frontend URL (used for post-payment redirects back to /settings)
PUBLIC_APP_URL=http://localhost:3000
# api_public_url — FastAPI backend URL (used as Paystack callback URL — must be reachable by browser)
API_PUBLIC_URL=http://localhost:8000

# === ENVIRONMENT ===
ENVIRONMENT=development
DEBUG=true

# === CORS ===
# Comma-separated list of allowed origins (e.g. production frontend URL)
ALLOWED_ORIGINS=https://app.routepass.com

# === SENTRY ERROR TRACKING (API only — web requires @sentry/nextjs Next.js 16 support) ===
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# === MANIFEST EMAIL (via Resend) ===
# Set MANIFEST_EMAIL to automatically email the trip manifest PDF on departure.
# RESEND_API_KEY is required; RESEND_FROM_EMAIL defaults to manifest@routepass.com
MANIFEST_EMAIL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=manifest@routepass.com
