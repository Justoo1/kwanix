# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://kwanix:secret@localhost:5432/kwanix_db

# DB role password for kwanix_app (non-superuser, subject to RLS).
# Must match the password used when migrations were first run.
# Generate with: openssl rand -hex 24
APP_ROLE_PASSWORD=

# === SECURITY ===
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === SESSION (Next.js) ===
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# === ARKESEL SMS ===
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=Kwanix

# === PAYMENTS ===
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_
FLUTTERWAVE_SECRET_KEY=

# === NEXT.JS ===
# Server-side (actions, server components inside Docker) — use Docker service name
API_INTERNAL_URL=http://api:8000
# Browser-side — use the host-exposed address
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === APP URLS ===
# public_app_url — Next.js frontend URL (used for post-payment redirects back to /settings)
PUBLIC_APP_URL=http://localhost:3000
# api_public_url — FastAPI backend URL (used as Paystack callback URL — must be reachable by browser)
API_PUBLIC_URL=http://localhost:8000

# === ENVIRONMENT ===
ENVIRONMENT=development
DEBUG=true

# === CORS ===
# Comma-separated list of allowed origins (e.g. production frontend URL)
ALLOWED_ORIGINS=https://kwanix.com

# === SENTRY ERROR TRACKING ===
# API (FastAPI)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Web (Next.js) — can be the same DSN or a separate Sentry project
# Generate auth token at: https://sentry.io/settings/account/api/auth-tokens/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# === MANIFEST EMAIL (via Resend) ===
# Set MANIFEST_EMAIL to automatically email the trip manifest PDF on departure.
# RESEND_API_KEY is required; RESEND_FROM_EMAIL defaults to manifest@kwanix.com
MANIFEST_EMAIL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=manifest@kwanix.com

# === AI INSIGHTS (Google Gemini) ===
# Powers the natural-language status card on the public parcel tracking page.
# Free tier: 15 requests/min, 1,500 requests/day — no billing required.
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
